{
  "displayName": "SLIs - rag-backend",
  "gridLayout": {
    "columns": "2",
    "widgets": [
      {
        "title": "SLI #1 — Tasa de errores 5xx",
        "xyChart": {
          "dataSets": [{
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"rag-backend\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_RATE",
                  "crossSeriesReducer": "REDUCE_SUM",
                  "groupByFields": ["metric.label.response_code_class"]
                }
              }
            },
            "plotType": "LINE"
          }],
          "timeshiftDuration": "0s",
          "yAxis": { "label": "Requests/seg", "scale": "LINEAR" }
        }
      },
      {
        "title": "SLI #2 — Latencia p95 (ms) · SLO < 8000",
        "xyChart": {
          "dataSets": [{
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/request_latencies\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"rag-backend\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_PERCENTILE_95",
                  "crossSeriesReducer": "REDUCE_MEAN"
                }
              }
            },
            "plotType": "LINE"
          }],
          "yAxis": { "label": "Latencia ms", "scale": "LINEAR" }
        }
      },
      {
        "title": "SLI #3 — Disponibilidad (requests 2xx vs total)",
        "xyChart": {
          "dataSets": [{
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"rag-backend\" metric.label.response_code_class=\"2xx\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_RATE",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "plotType": "STACKED_AREA"
          }],
          "yAxis": { "label": "Requests 2xx/seg", "scale": "LINEAR" }
        }
      },
      {
        "title": "Concurrencia — Instancias activas",
        "xyChart": {
          "dataSets": [{
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/container/instance_count\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"rag-backend\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_MEAN",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "plotType": "LINE"
          }],
          "yAxis": { "label": "Instancias", "scale": "LINEAR" }
        }
      },
      {
        "title": "SLI #4 — Cold start (p95 startup latency ms)",
        "xyChart": {
          "dataSets": [{
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/container/startup_latencies\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"rag-backend\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_PERCENTILE_95",
                  "crossSeriesReducer": "REDUCE_MEAN"
                }
              }
            },
            "plotType": "LINE"
          }],
          "yAxis": { "label": "Startup ms", "scale": "LINEAR" }
        }
      },
      {
        "title": "SLI #5 — Saturación CPU y memoria (p95 %)",
        "xyChart": {
          "dataSets": [
            {
              "legendTemplate": "CPU",
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/container/cpu/utilizations\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"rag-backend\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_PERCENTILE_95",
                    "crossSeriesReducer": "REDUCE_MEAN"
                  }
                }
              },
              "plotType": "LINE"
            },
            {
              "legendTemplate": "Memoria",
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/container/memory/utilizations\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"rag-backend\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_PERCENTILE_95",
                    "crossSeriesReducer": "REDUCE_MEAN"
                  }
                }
              },
              "plotType": "LINE"
            }
          ],
          "yAxis": { "label": "Utilización (0-1)", "scale": "LINEAR" }
        }
      },
      {
        "title": "SLI #6 — Throttling (respuestas 429/seg)",
        "xyChart": {
          "dataSets": [{
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.service_name=\"rag-backend\" metric.label.response_code=\"429\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_RATE",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "plotType": "LINE"
          }],
          "yAxis": { "label": "429/seg", "scale": "LINEAR" }
        }
      }
    ]
  }
}
